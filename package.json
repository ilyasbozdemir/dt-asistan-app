{
  "name": "dt-asistan-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:desktop": "pnpm --filter ./desktop dev",
    "dev:web": "pnpm --filter ./web dev",
    "dev": "pnpm dev:desktop",
    "build:desktop": "pnpm --filter ./desktop build",
    "build:web": "pnpm --filter ./web build",
    "typecheck:desktop": "pnpm --filter ./desktop typecheck",
    "typecheck:web": "pnpm --filter ./web build",
    "typecheck": "pnpm typecheck:desktop && pnpm typecheck:web",
    "format": "pnpm --filter ./desktop format",
    "lint": "pnpm --filter ./desktop lint && pnpm --filter ./web lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
