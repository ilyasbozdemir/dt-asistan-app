{
  "name": "dt-asistan-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:desktop": "pnpm --filter app-desktop dev",
    "dev:web": "pnpm --filter app-web dev",
    "dev:website": "pnpm --filter app-landing dev",
    "dev": "pnpm dev:desktop",
    "build:desktop": "pnpm --filter app-desktop build",
    "build:web": "pnpm --filter app-web build",
    "build:website": "pnpm --filter app-landing build",
    "typecheck:desktop": "pnpm --filter app-desktop typecheck",
    "typecheck:web": "pnpm --filter app-web build",
    "typecheck": "pnpm typecheck:desktop && pnpm typecheck:web",
    "format": "pnpm --filter app-desktop format",
    "lint": "pnpm --filter app-desktop lint && pnpm --filter app-web lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}